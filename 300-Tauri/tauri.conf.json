{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "deskset",
  "version": "0.1.0",
  "identifier": "com.nostalgia-season-train.deskset",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "manager",
        "label": "manager",
        "width": 800,
        "height": 600,
        "url": "manager.html"
      },
      {
        "title": "desktop",
        "label": "desktop",
        "width": 800,
        "height": 600,
        "url": "desktop.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
