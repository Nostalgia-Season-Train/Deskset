{
  "name": "Base",
  "author": "旧日丨四季列车",
  "version": "v0.0.1",
  "descript": "通过表格统计你的笔记，双击在 Obsidian 中打开",
  "model": {
    "width": {
      "type": "int",
      "default": 540
    },
    "height": {
      "type": "int",
      "default": 250
    },
    "noteFilter": {
      "type": "noteFilter",
      "default": {
        "match": "all",
        "filters": []
      }
    },
    "noteProp": {
      "type": "noteProp",
      "default": {
        "props": [{
          "dataKey": "file.fullname",
          "title": "📄 文件名",
          "width": 300
        }, {
          "dataKey": "file.mtime",
          "title": "📅 修改日期",
          "width": 200
        }]
      }
    },
    "noteSort": {
      "type": "noteSort",
      "default": {
        "sorts": []
      }
    },
    "noteGroup": {
      "type": "noteGroup",
      "default": {}
    }
  },
  "option": {
    "items": [],
    "tabs": [{
      "id": "filter",
      "text": "筛选",
      "items": [{
        "key": "noteFilter",
        "input": "NoteFilter"
      }]
    }, {
      "id": "prop",
      "text": "属性",
      "items": [{
        "key": "noteProp",
        "input": "NoteProp"
      }]
    }, {
      "id": "sort",
      "text": "排序",
      "items": [{
        "key": "noteSort",
        "input": "NoteSort"
      }]
    }, {
      "id": "group",
      "text": "分组",
      "items": [{
        "key": "noteGroup",
        "input": "NoteGroup"
      }]
    }]
  }
}
