{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Docs",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/100-Docs",
      "console": "integratedTerminal",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "docs:dev",
      ],
      "skipFiles": [
        "<node_internals>/**",
      ],
    },
    {
      "name": "Vite",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/200-Vite",
      "console": "integratedTerminal",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev",
      ],
      "skipFiles": [
        "<node_internals>/**",
      ],
    },
    {
      "name": "Tauri",
      "type": "node",  // 此处 node 作命令行使用
      "request": "launch",
      "cwd": "${workspaceFolder}/300-Tauri",
      "console": "integratedTerminal",
      "runtimeExecutable": "cargo",
      "runtimeArgs": [
        "run",
      ],
    },
  ],
  "compounds": [
    {
      "name": "Deskset",
      "configurations": [
        "Docs",
        "Vite",
        "Tauri",
      ],
    }
  ],
}